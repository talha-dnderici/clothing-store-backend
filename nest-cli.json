{
  "$schema": "https://json.schemastore.org/nest-cli",
  "monorepo": true,
  "root": "backend/apps/api-gateway",
  "sourceRoot": "backend/apps/api-gateway/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "tsConfigPath": "tsconfig.build.json"
  },
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "backend/apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "backend/apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.build.json"
      }
    },
    "login-service": {
      "type": "application",
      "root": "backend/apps/login-service",
      "entryFile": "main",
      "sourceRoot": "backend/apps/login-service/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.build.json"
      }
    },
    "register-service": {
      "type": "application",
      "root": "backend/apps/register-service",
      "entryFile": "main",
      "sourceRoot": "backend/apps/register-service/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.build.json"
      }
    },
    "main-service": {
      "type": "application",
      "root": "backend/apps/main-service",
      "entryFile": "main",
      "sourceRoot": "backend/apps/main-service/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.build.json"
      }
    },
    "card-service": {
      "type": "application",
      "root": "backend/apps/card-service",
      "entryFile": "main",
      "sourceRoot": "backend/apps/card-service/src",
      "compilerOptions": {
        "tsConfigPath": "tsconfig.build.json"
      }
    }
  }
}
